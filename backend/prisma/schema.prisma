generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        Int     	@id @default(autoincrement())
  createdAt DateTime	@default(now())
  email     String		@unique
  username  String		@unique
  role      String
  image     String?
  decks		Decks[]
  friends	Friends[]
  inboxUser	Inbox_users[]
  messages	Messages[]
  inbox		Inbox[]
}

model Friends {
	friendIds			Int[]
	userId				Int @id
	request_sent		Boolean
	created_at			DateTime @default(now())
	user				Users?	@relation(fields: [userId], references: [id])
}

model Decks {
	id			Int     @id @default(autoincrement())
	title		String?
	image		String?
	body		String?
	cards		Cards[]
	createdAt	DateTime @default(now())
	userId		Int?
	user		Users?	@relation(fields: [userId], references: [id])
}

model Cards {
	id			Int	@id @default(autoincrement())
	type		String
	element		String?
	hp			Int?
	name		String
	cap1		String?
	cap2		String?
	prize		Int?
	retreat		Int?
	weakness	String?
	resist		String?
	deckId		Int?
	deck		Decks?	@relation(fields: [deckId], references: [id])
}

model Messages {
	inbox_id	Int	@id
	user_id		Int?
	message		String?
	createdAt	DateTime @default(now())
	user		Users? @relation(fields: [user_id], references: [id])
	inbox		Inbox? @relation(fields: [inbox_id], references: [id])
}

model Inbox {
	id					Int	@id @default(autoincrement())
	inboxuid			String?
	last_message		String?
	last_sent_user_id	Int
	createdAt			DateTime @default(now())
	inboxUser			Inbox_users[]
	messages			Messages[]
	user				Users? @relation(fields: [last_sent_user_id], references: [id])
}

model Inbox_users {
	id				Int	@id @default(autoincrement())
	inbox_id		Int
	user_id			Int
	user			Users? @relation(fields: [user_id], references: [id])
	inbox			Inbox? @relation(fields: [inbox_id], references: [id])
}
