generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        Int     	@id @default(autoincrement())
  createdAt DateTime	@default(now())
  email     String		@unique
  username  String		@unique
  role      String
  image     String?
  decks		Decks[]
}

model Friends {
	first_friend_id		Int @id
	second_friend_id	Int?
	request_sent		Boolean
	created_at			DateTime @default(now())
}

model Decks {
	id			Int     @id @default(autoincrement())
	title		String?
	image		String?
	body		String?
	cards		Cards[]
	createdAt	DateTime @default(now())
	userId		Int?
	user		Users?	@relation(fields: [userId], references: [id])
}

model Cards {
	id			Int	@id @default(autoincrement())
	type		String
	element		String?
	hp			Int?
	name		String
	cap1		String?
	cap2		String?
	prize		Int?
	retreat		Int?
	weakness	String?
	resist		String?
	deckId		Int?
	deck		Decks?	@relation(fields: [deckId], references: [id])
}

model Messages {
	inbox_id			Int	@id
	user_id				Int?
	message				String?
	createdAt			DateTime @default(now())
}

model Inbox {
	id					Int	@id @default(autoincrement())
	inboxuid			String?
	last_sent_user_id	String?
	createdAt			DateTime @default(now())
}

model Inbox_users {
	id				Int	@id @default(autoincrement())
	inbox_id		Int?
	user_id			Int?
}
